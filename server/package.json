{
  "name": "life-in-weeks-api",
  "private": true,
  "version": "1.0.0",
  "description": "life-in-weeks 同步后端：Cloudflare Worker + D1",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:local": "wrangler d1 execute life-in-weeks --local --file=schema.sql",
    "db:remote": "wrangler d1 execute life-in-weeks --remote --file=schema.sql"
  },
  "devDependencies": {
    "wrangler": "^4"
  }
}
